# ============================================
# 🔐 API KEYS - مطلوبة Required
# ============================================

# ✅ DeepSeek API - لتوليد المحتوى النصي (3 لغات بطلب واحد)
# احصل على مفتاحك من: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

# ✅ Gemini API - لتوليد الصوت (TTS) فقط
# احصل على مفتاحك من: https://aistudio.google.com/
GEMINI_API_KEY_2=your_gemini_api_key_here
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# ✅ Pixabay API - للبحث عن فيديوهات
# احصل على مفتاحك من: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here
PIXABAY_API_URL=https://pixabay.com/api/videos/

# ============================================
# 🔐 API KEYS - اختيارية Optional
# ============================================

# ✅ Pexels API - مصدر إضافي للفيديوهات (اختياري)
# احصل على مفتاحك من: https://www.pexels.com/api/
PEXELS_API_KEY=
PEXELS_API_URL=https://api.pexels.com/videos/search

# ============================================
# 🤖 إعدادات نماذج DeepSeek للنصوص
# ============================================

# نماذج DeepSeek المتاحة:
# deepseek-chat     ← الأسرع والأرخص (مُوصى به)
# deepseek-reasoner ← أقوى للمحتوى المعقد
DEEPSEEK_MODELS=deepseek-chat,deepseek-reasoner

# ============================================
# 🎙️ إعدادات نموذج Gemini TTS للصوت
# ============================================

# نموذج Gemini للصوت:
# gemini-2.5-flash-preview-tts ← الوحيد الداعم للـ TTS
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# أصوات Gemini TTS المتاحة:
# Alnilam ← للعربية  (مُوصى به)
# Charon  ← للإنجليزية
# Aoede   ← للفرنسية
# Puck, Kore, Fenrir ← بدائل

# ============================================
# 🎬 إعدادات الفيديو
# ============================================

# جودة الفيديو: 720p | 1080p | 4K
VIDEO_QUALITY=1080p

# مدة الفيديو بالثواني
VIDEO_DURATION_MIN=40
VIDEO_DURATION_MAX=80

# إعدادات الصورة
VIDEO_FPS=30
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_BITRATE=8000k
AUDIO_BITRATE=320k

# ============================================
# 🎬 إعدادات FFmpeg
# ============================================

# ✅ اتركه فارغاً لاستخدام system FFmpeg (مُوصى به)
FFMPEG_PATH=

# عدد العمليات المتزامنة (1-4)
FFMPEG_CONCURRENCY=2

# ============================================
# 🌍 إعدادات اللغة والمحتوى
# ============================================

# اللغات المدعومة: ar | en | fr
# يتم توليد الـ 3 لغات بطلب DeepSeek واحد
LANGUAGES=ar,en,fr

# نوع المحتوى الافتراضي
# Motivational | Educational | Story | News | Tech | Lifestyle
CONTENT_TYPE=Motivational

# موضوع الفيديو الافتراضي
MAIN_TOPIC=النجاح والإصرار

# ============================================
# ⚙️ إعدادات البيئة
# ============================================

# development | production | test
NODE_ENV=development

# وضع التشغيل المتوازي: true | false
PARALLEL_MODE=false

# ============================================
# 📝 إعدادات السجلات
# ============================================

# مستوى السجل: error | warn | info | debug
LOG_LEVEL=info

# تفعيل وضع التصحيح
DEBUG_MODE=false

# تفعيل الكتابة للملف
LOG_TO_FILE=true
