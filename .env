# ============================================
# 🔐 API KEYS - مطلوبة Required
# ============================================

# ✅ Google Gemini API - لتوليد المحتوى النصي والصوت
# احصل على مفتاحك من: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-1.5-flash

# ✅ Google Cloud TTS - لتوليد الصوت
# احصل على مفتاحك من: https://console.cloud.google.com/
GOOGLE_TTS_URL=https://texttospeech.googleapis.com/v1

# ✅ Pixabay API - للبحث عن فيديوهات
# احصل على مفتاحك من: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here
PIXABAY_API_URL=https://pixabay.com/api/videos/

# ============================================
# 🔐 API KEYS - اختيارية Optional
# ============================================

# ✅ Pexels API - مصدر إضافي للفيديوهات (اختياري)
# احصل على مفتاحك من: https://www.pexels.com/api/
PEXELS_API_KEY=
PEXELS_API_URL=https://api.pexels.com/videos/search

# ============================================
# 🤖 إعدادات النماذج
# ============================================

# نماذج Gemini المتاحة (مرتبة من الأسرع للأقوى):
# gemini-1.5-flash  ← الأسرع + حصة أكبر (مُوصى به)
# gemini-1.5-pro    ← أقوى + حصة أقل
# gemini-2.0-flash  ← الأحدث
GEMINI_MODEL=gemini-1.5-flash

# نماذج Fallback (تُستخدم تلقائياً عند تجاوز الحصة)
GEMINI_FALLBACK_MODELS=gemini-1.5-flash,gemini-1.5-pro,gemini-2.0-flash

# ============================================
# 🎬 إعدادات الفيديو
# ============================================

# جودة الفيديو: 720p | 1080p | 4K
VIDEO_QUALITY=1080p

# مدة الفيديو بالثواني
VIDEO_DURATION_MIN=40
VIDEO_DURATION_MAX=80

# إعدادات الصورة
VIDEO_FPS=30
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_BITRATE=8000k
AUDIO_BITRATE=320k

# ============================================
# 🎬 إعدادات FFmpeg
# ============================================

# ✅ اتركه فارغاً لاستخدام system FFmpeg (مُوصى به)
# أو حدد المسار إذا كنت تستخدم ffmpeg-static محلياً
FFMPEG_PATH=

# عدد العمليات المتزامنة (1-4)
FFMPEG_CONCURRENCY=2

# ============================================
# 🌍 إعدادات اللغة والمحتوى
# ============================================

# اللغات المدعومة: ar | en | fr
# يمكن تحديد عدة لغات مفصولة بفاصلة
LANGUAGES=ar,en,fr

# نوع المحتوى الافتراضي
# Motivational | Educational | Story | News | Tech | Lifestyle
CONTENT_TYPE=Motivational

# موضوع الفيديو الافتراضي
MAIN_TOPIC=النجاح والإصرار

# ============================================
# ⚙️ إعدادات البيئة
# ============================================

# development | production | test
NODE_ENV=development

# وضع التشغيل المتوازي: true | false
# false = فيديو واحد في كل مرة (مُوصى به لتجنب 429)
PARALLEL_MODE=false

# ============================================
# 📝 إعدادات السجلات
# ============================================

# مستوى السجل: error | warn | info | debug
LOG_LEVEL=info

# تفعيل وضع التصحيح
DEBUG_MODE=false

# تفعيل الكتابة للملف
LOG_TO_FILE=true
